# ============================================================
# FlashLink 环境变量配置
# 复制此文件为 .env 并修改实际值
# ============================================================

# ---------- 应用端口 ----------
APP_PORT=8080
MANAGEMENT_PORT=8081

# ---------- MySQL 数据库 (docker-compose 内置服务) ----------
DB_HOST=mysql
DB_PORT=3306
DB_NAME=flash_link
DB_USERNAME=flashlink
DB_PASSWORD=

# MySQL root 密码
MYSQL_ROOT_PASSWORD=

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ---------- 功能开关 ----------
SWAGGER_ENABLED=false
PROMETHEUS_ENABLED=true

# ============================================================
# 容器资源限制 (服务器总内存 1.6Gi，可用约 1.1Gi)
# 分配方案：App 480M + MySQL 320M + Redis 80M = 880M
# 留约 250M 给 OS / Docker daemon
# ============================================================
APP_MEM_LIMIT=480m
APP_MEM_RESERVE=320m
MYSQL_MEM_LIMIT=320m
MYSQL_MEM_RESERVE=240m
REDIS_MEM_LIMIT=80m
REDIS_MEM_RESERVE=32m